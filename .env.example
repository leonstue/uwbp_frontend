# API-Modus
#
# - Leer/auskommentiert: Mock-Modus (in-memory Daten, keine echten Backend-Calls).
# - Gesetzt: Real-Modus.
#
# Wert ist die Backend-Origin OHNE /api am Ende. Das Frontend hängt /api/...
# selbst dran — VITE_API_URL=http://uwbp:8080 wird zu http://uwbp:8080/api/...
#
# Im Dev nutzen wir den Vite-Proxy (vite.config.js), dort reicht VITE_API_URL=/api
# (das wird intern auf VITE_BACKEND_URL gemappt). In Production muss die volle URL
# her, weil der Vite-Proxy nur in dev läuft.
#
# VITE_API_URL=/api                    # dev gegen Backend via Proxy
# VITE_API_URL=http://uwbp:8080        # production gegen Pi
# VITE_API_URL=http://10.42.0.1:8080   # fallback ohne mDNS-Alias

# Ziel des Vite-Proxys (nur dev). Default: http://uwbp:8080
# VITE_BACKEND_URL=http://uwbp:8080

# Polling-Intervalle (ms). Async-Loop garantiert: kein Stacking, frühestens nach
# Antwort + delay.
VITE_POLL_INTERVAL_POSITIONS=80
VITE_POLL_INTERVAL_DEVICES=2000

# Pro-Request Timeout (ms). Hängende Calls werden via AbortController gekillt.
VITE_REQUEST_TIMEOUT_MS=1500

VITE_HISTORY_BUFFER_SECONDS=600
VITE_STATUS_ONLINE_THRESHOLD_MS=1000
VITE_STATUS_DELAYED_THRESHOLD_MS=5000
