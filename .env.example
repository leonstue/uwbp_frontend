# Wenn gesetzt: echte API über Vite-Proxy auf /api (kein CORS).
# Wenn leer/auskommentiert: Mock-Modus (in-memory Daten).
# VITE_API_URL=/api

# Ziel des Vite-Proxys (nur dev). Default: http://uwbp:8080
# VITE_BACKEND_URL=http://uwbp:8080

VITE_POLL_INTERVAL_POSITIONS=150
VITE_POLL_INTERVAL_DEVICES=2000
VITE_HISTORY_BUFFER_SECONDS=600
VITE_STATUS_ONLINE_THRESHOLD_MS=5000
VITE_STATUS_DELAYED_THRESHOLD_MS=30000
