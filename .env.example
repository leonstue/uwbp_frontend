# API-Modus
#
# - Leer/auskommentiert: Mock-Modus (in-memory Daten, keine echten Backend-Calls).
# - Gesetzt: Real-Modus.
#
# Wenn leer/auskommentiert: Mock-Modus. Wenn gesetzt: Real-Modus.
#
# Empfohlen: VITE_API_URL=/api
#
# - In dev: Vite-Proxy in vite.config.js routed /api → VITE_BACKEND_URL.
# - In prod (adapter-node): hooks.server.js proxied /api → BACKEND_URL
#   (server-side, kein CORS, gleiche Origin im Browser).
#
# So bleibt das Frontend immer auf der gleichen Origin, kein CORS-Preflight,
# keine Cross-Origin-Probleme.
#
# VITE_API_URL=/api

# Ziel des Vite-Proxys (nur dev). Default: http://uwbp:8080
# VITE_BACKEND_URL=http://uwbp:8080

# Ziel des Production-Proxys (server-side hook, nur prod). Default: http://uwbp:8080
# Diese Variable wird von Node beim Start gelesen, nicht vom Build.
# BACKEND_URL=http://uwbp:8080
# PROXY_TIMEOUT_MS=2000

# Polling-Intervalle (ms). Async-Loop garantiert: kein Stacking, frühestens nach
# Antwort + delay.
VITE_POLL_INTERVAL_POSITIONS=80
VITE_POLL_INTERVAL_DEVICES=2000

# Pro-Request Timeout (ms). Hängende Calls werden via AbortController gekillt.
VITE_REQUEST_TIMEOUT_MS=1500

VITE_HISTORY_BUFFER_SECONDS=600
VITE_STATUS_ONLINE_THRESHOLD_MS=1000
VITE_STATUS_DELAYED_THRESHOLD_MS=5000
