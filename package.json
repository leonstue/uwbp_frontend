{
	"name": "uwbp-frontend",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"start": "node build",
		"prepare": "svelte-kit sync || echo ''",
		"format": "prettier --write .",
		"lint": "prettier --check . && eslint .",
		"check": "svelte-kit sync && svelte-check --tsconfig ./jsconfig.json --tsgo",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./jsconfig.json --tsgo --watch"
	},
	"devDependencies": {
		"@eslint/js": "^10.0.1",
		"@sveltejs/adapter-node": "^5.5.4",
		"@sveltejs/kit": "^2.57.0",
		"@sveltejs/vite-plugin-svelte": "^7.0.0",
		"@types/node": "^25.6.0",
		"@typescript/native-preview": "^7.0.0-dev.20260504.1",
		"eslint": "^10.2.1",
		"eslint-plugin-svelte": "^3.17.1",
		"globals": "^17.5.0",
		"prettier": "^3.8.3",
		"prettier-plugin-svelte": "^3.5.1",
		"svelte": "^5.55.2",
		"svelte-check": "^4.4.7",
		"typescript": "^6.0.3",
		"vite": "^8.0.7"
	},
	"dependencies": {
		"@threlte/core": "^8.5.11",
		"@threlte/extras": "^9.15.0",
		"dayjs": "^1.11.20",
		"flatpickr": "^4.6.13",
		"lucide-svelte": "^1.0.1",
		"three": "^0.184.0"
	}
}
